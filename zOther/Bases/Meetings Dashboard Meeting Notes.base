views:
  - type: table
    name: Table
    filters:
      and:
        - meetingType != "standup"
        - type == "Meeting"
        - file.folder == "01. General/Meetings"
    order:
      - file.name
      - type
      - date
      - teams
      - projects
      - tags
      - summary
    sort:
      - property: date
        direction: DESC
    limit: 5
    columnSize: {}
